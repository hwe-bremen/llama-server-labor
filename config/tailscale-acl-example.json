// tailscale-acl-example.json — Referenz-ACL fuer den Lab-Zugriff.
//
// EINSATZ: login.tailscale.com -> Access Controls (Tailnet policy file).
// Tailscale nutzt HuJSON (JSON mit // Kommentaren). Diese Datei ist eine
// VORLAGE — im Admin einfuegen, mit dem eingebauten Preview/Tester pruefen,
// erst dann speichern. Eine restriktive Policy ersetzt die Default-Regel
// "alle Geraete duerfen alles" und kann andere Zugriffe (SSH etc.) brechen.
//
// Rollen ueber Tags statt Geraetenamen: neue Geraete (z.B. der Mac-mini)
// brauchen dann nur den passenden Tag, die ACL bleibt unveraendert.
//   tag:llm-server  = Geraete, die den Chat-Dienst anbieten (macbook, mac-mini)
//   tag:llm-client  = Geraete, die zugreifen duerfen (ipad165, iphone181)
//
// Geraete taggen: Admin-Konsole -> Machines -> Geraet -> Edit ACL tags,
// oder beim Anmelden:  tailscale up --advertise-tags=tag:llm-server
{
  "tagOwners": {
    "tag:llm-server": ["autogroup:owner"],
    "tag:llm-client": ["autogroup:owner"]
  },

  "acls": [
    // Nur llm-Clients duerfen das Chat-UI (Port 8080) auf llm-Servern erreichen.
    // Gilt auch fuer Tailscale Serve (Serve unterliegt denselben ACLs).
    {
      "action": "accept",
      "src": ["tag:llm-client"],
      "dst": ["tag:llm-server:8080"]
    }

    // HINWEIS: Ohne weitere accept-Regeln ist alles Uebrige im Tailnet gesperrt
    // (Tailscale kennt nur allow, keine deny). Brauchst du deinen eigenen
    // Voll-Zugriff (Admin/SSH/andere Dienste), ergaenze bewusst — das oeffnet
    // dann aber auch 8080 fuer diese Geraete, da es keine deny-Regeln gibt:
    //   , { "action": "accept", "src": ["autogroup:owner"], "dst": ["*:*"] }
  ]

  // Fuer ein reines Ein-Personen-Tailnet ist die Alternative, die Default-
  // Allow-All zu belassen: dann schuetzt v.a. die Tailnet-Grenze (privat,
  // WireGuard-verschluesselt, niemand von aussen). Die Tag-Beschraenkung oben
  // ist die zusaetzliche Haertung, wenn du das Tailnet teilst oder maximale
  // Isolation willst.
}
